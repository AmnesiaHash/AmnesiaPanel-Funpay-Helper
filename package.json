{
  "name": "amnesia-panel",
  "version": "1.1.0",
  "description": "AmnesiaPanel — free open-source FunPay lot manager (Electron)",
  "type": "module",
  "main": "./out/main/index.js",
  "author": "AmnesiaOwner",
  "license": "MIT",
  "private": true,
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack": "npm run build && electron-builder --dir --publish never",
    "dist": "npm run build && electron-builder --win nsis --publish never",
    "portable": "npm run pack && node scripts/make-portable.mjs",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "postinstall": "node scripts/install-electron.mjs"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.5",
    "cheerio": "^1.0.0",
    "dotenv": "^16.5.0",
    "framer-motion": "^12.6.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.5.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron/get": "^3.1.0",
    "@eslint/js": "^9.24.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "electron": "35.7.5",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "eslint": "^9.24.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "extract-zip": "^2.0.1",
    "globals": "^16.0.0",
    "png-to-ico": "^3.0.2",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.0",
    "vite": "^6.2.5"
  }
}
